      "content": "\u00ce\u0093\u00ce\u00b5\u00ce\u00b9\u00ce\u00b1 \u00cf\u0083\u00ce\u00b1\u00cf\u0082 \u00f0\u009f\u0099\u0082\n\u00ce\u0095\u00ce\u00af\u00ce\u00b4\u00ce\u00b1 \u00cf\u0084\u00ce\u00b7\u00ce\u00bd \u00ce\u00b1\u00ce\u00b3\u00ce\u00b3\u00ce\u00b5\u00ce\u00bb\u00ce\u00af\u00ce\u00b1 \u00cf\u0083\u00ce\u00b1\u00cf\u0082 \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00ce\u00b1\u00cf\u0080\u00ce\u00bf\u00cf\u0086\u00ce\u00ac\u00cf\u0083\u00ce\u00b9\u00cf\u0083\u00ce\u00b1 \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b5\u00cf\u0080\u00ce\u00b9\u00ce\u00ba\u00ce\u00bf\u00ce\u00b9\u00ce\u00bd\u00cf\u0089\u00ce\u00bd\u00ce\u00ae\u00cf\u0083\u00cf\u0089 \u00ce\u00bc\u00ce\u00b1\u00ce\u00b6\u00ce\u00af \u00cf\u0083\u00ce\u00b1\u00cf\u0082.\n\u00ce\u0091\u00cf\u0083\u00cf\u0087\u00ce\u00bf\u00ce\u00bb\u00ce\u00bf\u00cf\u008d\u00ce\u00bc\u00ce\u00b1\u00ce\u00b9 \u00ce\u00b5\u00ce\u00bd\u00ce\u00b5\u00cf\u0081\u00ce\u00b3\u00ce\u00ac \u00ce\u00bc\u00ce\u00b5 tattoo \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00ce\u00b4\u00ce\u00bf\u00cf\u0085\u00ce\u00bb\u00ce\u00b5\u00cf\u008d\u00cf\u0089 \u00ce\u00ae\u00ce\u00b4\u00ce\u00b7 \u00cf\u0083\u00ce\u00b5 \u00cf\u0080\u00cf\u0081\u00ce\u00b1\u00ce\u00b3\u00ce\u00bc\u00ce\u00b1\u00cf\u0084\u00ce\u00b9\u00ce\u00ba\u00cf\u008c \u00ce\u00b4\u00ce\u00ad\u00cf\u0081\u00ce\u00bc\u00ce\u00b1, \u00ce\u00ba\u00cf\u0085\u00cf\u0081\u00ce\u00af\u00cf\u0089\u00cf\u0082 \u00cf\u0083\u00ce\u00b5 fine line \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 black & grey. \u00ce\u0091\u00cf\u0085\u00cf\u0084\u00ce\u00ae \u00cf\u0084\u00ce\u00b7\u00ce\u00bd \u00cf\u0080\u00ce\u00b5\u00cf\u0081\u00ce\u00af\u00ce\u00bf\u00ce\u00b4\u00ce\u00bf \u00ce\u00b1\u00ce\u00bd\u00ce\u00b1\u00ce\u00b6\u00ce\u00b7\u00cf\u0084\u00cf\u008e \u00ce\u00ad\u00ce\u00bd\u00ce\u00b1 studio \u00cf\u008c\u00cf\u0080\u00ce\u00bf\u00cf\u0085 \u00ce\u00bc\u00cf\u0080\u00ce\u00bf\u00cf\u0081\u00cf\u008e \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b5\u00ce\u00be\u00ce\u00b5\u00ce\u00bb\u00ce\u00b9\u00cf\u0087\u00ce\u00b8\u00cf\u008e \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b4\u00ce\u00bf\u00cf\u0085\u00ce\u00bb\u00ce\u00b5\u00cf\u008d\u00cf\u0089 \u00cf\u0083\u00cf\u0084\u00ce\u00b1\u00ce\u00b8\u00ce\u00b5\u00cf\u0081\u00ce\u00ac \u00cf\u0089\u00cf\u0082 tattoo artist.\n\u00ce\u0091\u00ce\u00bd \u00ce\u00b8\u00ce\u00ad\u00ce\u00bb\u00ce\u00b5\u00cf\u0084\u00ce\u00b5, \u00ce\u00bc\u00cf\u0080\u00ce\u00bf\u00cf\u0081\u00cf\u008e \u00ce\u00bd\u00ce\u00b1 \u00cf\u0083\u00ce\u00b1\u00cf\u0082 \u00cf\u0083\u00cf\u0084\u00ce\u00b5\u00ce\u00af\u00ce\u00bb\u00cf\u0089 portfolio \u00ce\u00ae \u00ce\u00bd\u00ce\u00b1 \u00cf\u0080\u00ce\u00b5\u00cf\u0081\u00ce\u00ac\u00cf\u0083\u00cf\u0089 \u00ce\u00b1\u00cf\u0080\u00cf\u008c \u00ce\u00ba\u00ce\u00bf\u00ce\u00bd\u00cf\u0084\u00ce\u00ac \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b3\u00ce\u00bd\u00cf\u0089\u00cf\u0081\u00ce\u00b9\u00cf\u0083\u00cf\u0084\u00ce\u00bf\u00cf\u008d\u00ce\u00bc\u00ce\u00b5.\n\n\u00ce\u0095\u00cf\u0085\u00cf\u0087\u00ce\u00b1\u00cf\u0081\u00ce\u00b9\u00cf\u0083\u00cf\u0084\u00cf\u008e \u00cf\u0080\u00ce\u00bf\u00ce\u00bb\u00cf\u008d \u00f0\u009f\u00a4\u008d",
