      "content": "\u00ce\u0093\u00ce\u00b5\u00ce\u00b9\u00ce\u00b1 \u00cf\u0083\u00ce\u00b1\u00cf\u0082, \u00ce\u00ad\u00cf\u0087\u00ce\u00bf\u00cf\u0085\u00ce\u00bc\u00ce\u00b5 \u00ce\u00bb\u00ce\u00ac\u00ce\u00b2\u00ce\u00b5\u00ce\u00b9 \u00cf\u0084\u00ce\u00bf \u00ce\u00bc\u00ce\u00ae\u00ce\u00bd\u00cf\u0085\u00ce\u00bc\u00ce\u00ac \u00cf\u0083\u00ce\u00b1\u00cf\u0082 \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00ce\u00b5\u00cf\u0085\u00cf\u0087\u00ce\u00b1\u00cf\u0081\u00ce\u00b9\u00cf\u0083\u00cf\u0084\u00ce\u00bf\u00cf\u008d\u00ce\u00bc\u00ce\u00b5 \u00cf\u0080\u00ce\u00bf\u00cf\u0085 \u00ce\u00b5\u00cf\u0080\u00ce\u00b9\u00ce\u00ba\u00ce\u00bf\u00ce\u00b9\u00ce\u00bd\u00cf\u0089\u00ce\u00bd\u00ce\u00ae\u00cf\u0083\u00ce\u00b1\u00cf\u0084\u00ce\u00b5 \u00ce\u00bc\u00ce\u00b1\u00ce\u00b6\u00ce\u00af \u00ce\u00bc\u00ce\u00b1\u00cf\u0082. \u00ce\u0091\u00ce\u00bd \u00ce\u00b5\u00ce\u00bd\u00ce\u00b4\u00ce\u00b9\u00ce\u00b1\u00cf\u0086\u00ce\u00ad\u00cf\u0081\u00ce\u00b5\u00cf\u0083\u00cf\u0084\u00ce\u00b5 \u00ce\u00b3\u00ce\u00b9\u00ce\u00b1 tattoo \u00cf\u0083\u00cf\u0084\u00ce\u00b5\u00ce\u00af\u00ce\u00bb\u00cf\u0084\u00ce\u00b5 \u00ce\u00bc\u00ce\u00b1\u00cf\u0082 \u00cf\u0086\u00cf\u0089\u00cf\u0084\u00ce\u00bf\u00ce\u00b3\u00cf\u0081\u00ce\u00b1\u00cf\u0086\u00ce\u00af\u00ce\u00b1 \u00cf\u0084\u00ce\u00b9 \u00cf\u0083\u00cf\u0087\u00ce\u00ad\u00ce\u00b4\u00ce\u00b9\u00ce\u00bf \u00ce\u00b8\u00ce\u00ad\u00ce\u00bb\u00ce\u00b5\u00cf\u0084\u00ce\u00b5 \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00cf\u0084\u00ce\u00b9 \u00ce\u00bc\u00ce\u00ad\u00ce\u00b3\u00ce\u00b5\u00ce\u00b8\u00ce\u00bf\u00cf\u0082 \u00cf\u0083\u00cf\u0084\u00ce\u00bf \u00cf\u0080\u00ce\u00b5\u00cf\u0081\u00ce\u00af\u00cf\u0080\u00ce\u00bf\u00cf\u0085 , \u00ce\u00b3\u00ce\u00b9\u00ce\u00b1 \u00ce\u00bd\u00ce\u00b1 \u00ce\u00bc\u00ce\u00ac\u00ce\u00b8\u00ce\u00b5\u00cf\u0084\u00ce\u00b5 \u00cf\u0084\u00ce\u00b9\u00ce\u00bc\u00ce\u00ae \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00ce\u00b3\u00ce\u00b9\u00ce\