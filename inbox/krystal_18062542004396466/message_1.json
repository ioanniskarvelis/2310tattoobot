      "content": "\u00ce\u009a\u00ce\u00b1\u00ce\u00bb\u00ce\u00b7\u00cf\u0083\u00cf\u0080\u00ce\u00ad\u00cf\u0081\u00ce\u00b1 \u00ce\u00b8\u00ce\u00b1 \u00ce\u00ba\u00cf\u0081\u00ce\u00b9\u00ce\u00b8\u00ce\u00b5\u00ce\u00af \u00ce\u00b1\u00ce\u00bd\u00ce\u00ac\u00ce\u00bb\u00ce\u00bf\u00ce\u00b3\u00ce\u00b1 \u00cf\u0084\u00ce\u00bf \u00cf\u0084\u00ce\u00b5\u00ce\u00bb\u00ce\u00b9\u00ce\u00ba\u00cf\u008c \u00ce\u00bc\u00ce\u00ad\u00ce\u00b3\u00ce\u00b5\u00ce\u00b8\u00ce\u00bf\u00cf\u0082 \u00cf\u0080\u00ce\u00bf\u00cf\u0085 \u00ce\u00b8\u00ce\u00b1 \u00ce\u00b4\u00ce\u00b9\u00ce\u00b1\u00ce\u00bb\u00ce\u00ad\u00ce\u00be\u00ce\u00b5\u00cf\u0084\u00ce\u00b5 , \u00ce\u00b3\u00ce\u00b9\u00ce\u00b1 \u00cf\u0084\u00ce\u00bf \u00cf\u0080\u00cf\u0081\u00cf\u008e\u00cf\u0084\u00ce\u00bf \u00cf\u0080\u00cf\u0087 \u00ce\u00bc\u00cf\u0080\u00ce\u00bf\u00cf\u0081\u00ce\u00b5\u00ce\u00af \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b2\u00ce\u00b3\u00ce\u00b5\u00ce\u00b9 \u00ce\u00b1\u00cf\u0080\u00cf\u008c 120 \u00ce\u00bc\u00ce\u00ad\u00cf\u0087\u00cf\u0081\u00ce\u00b9 180 \n\u00ce\u0093\u00ce\u00b9\u00ce\u00b1 \u00cf\u0084\u00ce\u00bf \u00ce\u00b4\u00ce\u00b5\u00cf\u008d\u00cf\u0084\u00ce\u00b5\u00cf\u0081\u00ce\u00bf 120 \u00ce\u00bc\u00ce\u00ad\u00cf\u0087\u00cf\u0081\u00ce\u00b9 160",
