    {
      "sender_name": "2310tattoo studio by Christina",
      "timestamp_ms": 1771271272207,
      "content": "\u00ce\u0094\u00ce\u00b7\u00ce\u00bb\u00cf\u008e\u00ce\u00bd\u00cf\u0089 \u00cf\u0085\u00cf\u0080\u00ce\u00b5\u00cf\u008d\u00ce\u00b8\u00cf\u0085\u00ce\u00bd\u00ce\u00b1 \u00cf\u008c\u00cf\u0084\u00ce\u00b9 \u00ce\u00b5\u00ce\u00af\u00ce\u00bc\u00ce\u00b1\u00ce\u00b9 \u00ce\u00bf \u00ce\u00bd\u00cf\u008c\u00ce\u00bc\u00ce\u00b9\u00ce\u00bc\u00ce\u00bf\u00cf\u0082 \u00ce\u00b3\u00ce\u00bf\u00ce\u00bd\u00ce\u00ad\u00ce\u00b1\u00cf\u0082 / \u00ce\u00ba\u00ce\u00b7\u00ce\u00b4\u00ce\u00b5\u00ce\u00bc\u00cf\u008c\u00ce\u00bd\u00ce\u00b1\u00cf\u0082 \u00cf\u0084\u00ce\u00bf\u00cf\u0085/\u00cf\u0084\u00ce\u00b7\u00cf\u0082 \u00ce\u00b1\u00ce\u00bd\u00ce\u00b7\u00ce\u00bb\u00ce\u00af\u00ce\u00ba\u00ce\u00bf\u00cf\u0085:\n\n\u00ce\u009f\u00ce\u00bd\u00ce\u00bf\u00ce\u00bc\u00ce\u00b1\u00cf\u0084\u00ce\u00b5\u00cf\u0080\u00cf\u008e\u00ce\u00bd\u00cf\u0085\u00ce\u00bc\u00ce\u00bf \u00ce\u0091\u00ce\u00bd\u00ce\u00b7\u00ce\u00bb\u00ce\u00af\u00ce\u00ba\u00ce\u00bf\u00cf\u0085: __________________________\n\u00ce\u0097\u00ce\u00bc\u00ce\u00b5\u00cf\u0081\u00ce\u00bf\u00ce\u00bc\u00ce\u00b7\u00ce\u00bd\u00ce\u00af\u00ce\u00b1 \u00ce\u0093\u00ce\u00ad\u00ce\u00bd\u00ce\u00bd\u00ce\u00b7\u00cf\u0083\u00ce\u00b7\u00cf\u0082: __________________________\n\n\u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00cf\u0080\u00ce\u00b1\u00cf\u0081\u00ce\u00ad\u00cf\u0087\u00cf\u0089 \u00cf\u0084\u00ce\u00b7 \u00cf\u0083\u00cf\u0085\u00ce\u00b3\u00ce\u00ba\u00ce\u00b1\u00cf\u0084\u00ce\u00ac\u00ce\u00b8\u00ce\u00b5\u00cf\u0083\u00ce\u00ae \u00ce\u00bc\u00ce\u00bf\u00cf\u0085 \u00ce\u00b3\u00ce\u00b9\u00ce\u00b1 \u00cf\u0084\u00ce\u00b7\u00ce\u00bd \u00cf\u0080\u00cf\u0081\u00ce\u00b1\u00ce\u00b3\u00ce\u00bc\u00ce\u00b1\u00cf\u0084\u00ce\u00bf\u00cf\u0080\u00ce\u00bf\u00ce\u00af\u00ce\u00b7\u00cf\u0083\u00ce\u00b7 \u00cf\u0084\u00ce\u00b1\u00cf\u0084\u00ce\u00bf\u00cf\u0085\u00ce\u00ac\u00ce\u00b6 \u00ce\u00b1\u00cf\u0080\u00cf\u008c \u00cf\u0084\u00ce\u00b7\u00ce\u00bd \u00ce\u00b5\u00cf\u0080\u00ce\u00b9\u00cf\u0087\u00ce\u00b5\u00ce\u00af\u00cf\u0081\u00ce\u00b7\u00cf\u0083\u00ce\u00b7:\n\n2310 \u00ce\u0095.\u00ce\u0095\n\u00ce\u0091\u00ce\u00a6\u00ce\u009c: 801665138\n\u00ce\u0091\u00ce\u00b3\u00ce\u00af\u00ce\u00bf\u00cf\u0085 \u00ce\u00a3\u00ce\u00b5\u00cf\u0081\u00ce\u00b1\u00cf\u0086\u00ce\u00b5\u00ce\u00af\u00ce\u00bc 4, \u00ce\u0098\u00ce\u00b5\u00cf\u0083\u00cf\u0083\u00ce\u00b1\u00ce\u00bb\u00ce\u00bf\u00ce\u00bd\u00ce\u00af\u00ce\u00ba\u00ce\u00b7\n\n\u00e2\u00b8\u00bb\n\n\u00ce\u0094\u00ce\u0097\u00ce\u009b\u00ce\u00a9\u00ce\u00a3\u00ce\u0097\n\n\u00ce\u0094\u00ce\u00b7\u00ce\u00bb\u00cf\u008e\u00ce\u00bd\u00cf\u0089 \u00cf\u008c\u00cf\u0084\u00ce\u00b9:\n\n\u00e2\u0080\u00a2 \u00ce\u0088\u00cf\u0087\u00cf\u0089 \u00ce\u00b5\u00ce\u00bd\u00ce\u00b7\u00ce\u00bc\u00ce\u00b5\u00cf\u0081\u00cf\u0089\u00ce\u00b8\u00ce\u00b5\u00ce\u00af \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00cf\u0083\u00cf\u0085\u00ce\u00bd\u00ce\u00b1\u00ce\u00b9\u00ce\u00bd\u00cf\u008e \u00cf\u0083\u00cf\u0084\u00ce\u00b7\u00ce\u00bd \u00cf\u0080\u00cf\u0081\u00ce\u00b1\u00ce\u00b3\u00ce\u00bc\u00ce\u00b1\u00cf\u0084\u00ce\u00bf\u00cf\u0080\u00ce\u00bf\u00ce\u00af\u00ce\u00b7\u00cf\u0083\u00ce\u00b7 \u00cf\u0084\u00ce\u00bf\u00cf\u0085 \u00cf\u0084\u00ce\u00b1\u00cf\u0084\u00ce\u00bf\u00cf\u0085\u00ce\u00ac\u00ce\u00b6.\n\u00e2\u0080\u00a2 \u00ce\u009f \u00ce\u00b1\u00ce\u00bd\u00ce\u00ae\u00ce\u00bb\u00ce\u00b9\u00ce\u00ba\u00ce\u00bf\u00cf\u0082 \u00ce\u00b4\u00ce\u00b5\u00ce\u00bd \u00ce\u00ad\u00cf\u0087\u00ce\u00b5\u00ce\u00b9 \u00ce\u00ba\u00ce\u00ac\u00cf\u0080\u00ce\u00bf\u00ce\u00b9\u00ce\u00bf \u00ce\u00b8\u00ce\u00ad\u00ce\u00bc\u00ce\u00b1 \u00cf\u0080\u00ce\u00bf\u00cf\u0085 \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b5\u00ce\u00bc\u00cf\u0080\u00ce\u00bf\u00ce\u00b4\u00ce\u00af\u00ce\u00b6\u00ce\u00b5\u00ce\u00b9 \u00cf\u0084\u00ce\u00b7 \u00ce\u00b4\u00ce\u00b9\u00ce\u00b1\u00ce\u00b4\u00ce\u00b9\u00ce\u00ba\u00ce\u00b1\u00cf\u0083\u00ce\u00af\u00ce\u00b1 \u00ce\u00ae \u00cf\u0084\u00ce\u00bf \u00ce\u00b1\u00ce\u00bd\u00ce\u00b1\u00ce\u00bb\u00ce\u00b1\u00ce\u00bc\u00ce\u00b2\u00ce\u00ac\u00ce\u00bd\u00cf\u0089 \u00ce\u00bc\u00ce\u00b5 \u00ce\u00b4\u00ce\u00b9\u00ce\u00ba\u00ce\u00ae \u00ce\u00bc\u00ce\u00bf\u00cf\u0085 \u00ce\u00b5\u00cf\u0085\u00ce\u00b8\u00cf\u008d\u00ce\u00bd\u00ce\u00b7.\n\u00e2\u0080\u00a2 \u00ce\u0093\u00ce\u00bd\u00cf\u0089\u00cf\u0081\u00ce\u00af\u00ce\u00b6\u00cf\u0089 \u00cf\u008c\u00cf\u0084\u00ce\u00b9 \u00cf\u0084\u00ce\u00bf \u00cf\u0084\u00ce\u00b1\u00cf\u0084\u00ce\u00bf\u00cf\u0085\u00ce\u00ac\u00ce\u00b6 \u00ce\u00b5\u00ce\u00af\u00ce\u00bd\u00ce\u00b1\u00ce\u00b9 \u00ce\u00bc\u00cf\u008c\u00ce\u00bd\u00ce\u00b9\u00ce\u00bc\u00ce\u00bf \u00ce\u00ba\u00ce\u00b1\u00ce\u00b9 \u00ce\u00bc\u00cf\u0080\u00ce\u00bf\u00cf\u0081\u00ce\u00b5\u00ce\u00af \u00ce\u00bd\u00ce\u00b1 \u00ce\u00b5\u00ce\u00af\u00ce\u00bd\u00ce\u00b1\u00ce\u00b9 \u00ce\u00bc\u00ce\u00b5\u00ce\u00b3\u00ce\u00ac\u00ce\u00bb\u00cf\u0089\u00ce\u00bd \u00ce\u00b4\u00ce\u00b9\u00ce\u00b1\u00cf\u0083\u00cf\u0084\u00ce\u00ac\u00cf\u0083\u00ce\u00b5\u00cf\u0089\u00ce\u00bd \u00ce\u00ae \u00cf\u0083\u00ce\u00b5 \u00ce\u00b5\u00ce\u00bc\u00cf\u0086\u00ce\u00b1\u00ce\u00bd\u00ce\u00ad\u00cf\u0082 \u00cf\u0083\u00ce\u00b7\u00ce\u00bc\u00ce\u00b5\u00ce\u00af\u00ce\u00bf \u00cf\u0083\u00cf\u008e\u00ce\u00bc\u00ce\u00b1\u00cf\u0084\u00ce\u00bf\u00cf\u0082.\n\u00e2\u0080\u00a2 \u00ce\u0091\u00ce\u00bd\u00ce\u00b1\u00ce\u00bb\u00ce\u00b1\u00ce\u00bc\u00ce\u00b2\u00ce\u00ac\u00ce\u00bd\u00cf\u0089 \u00cf\u0080\u00ce\u00bb\u00ce\u00ae\u00cf\u0081\u00cf\u0089\u00cf\u0082 \u00cf\u0084\u00ce\u00b7\u00ce\u00bd \u00ce\u00b5\u00cf\u0085\u00ce\u00b8\u00cf\u008d\u00ce\u00bd\u00ce\u00b7 \u00cf\u0084\u00ce\u00b7\u00cf\u0082 \u00ce\u00b1\u00cf\u0080\u00cf\u008c\u00cf\u0086\u00ce\u00b1\u00cf\u0083\u00ce\u00b7\u00cf\u0082 \u00ce\u00b3\u00ce\u00b9\u00ce\u00b1 \u00cf\u0084\u00ce\u00bf\u00ce\u00bd \u00ce\u00b1\u00ce\u00bd\u00ce\u00ae\u00ce\u00bb\u00ce\u00b9\u